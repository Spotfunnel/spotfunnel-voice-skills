# Secrets — never commit
.env
*.local.env

# Per-customer runs (large, ephemeral, contains scraped customer data)
**/runs/
!**/runs/.gitkeep

# Operator's per-machine cached env path
~/.config/spotfunnel-skills/

# Logs and OS junk
*.log
.DS_Store
Thumbs.db

# Editor / tool caches
.vscode/
.idea/
node_modules/
__pycache__/
.pytest_cache/

# Temp dirs created by skill scripts
.tmp-*/

# (No exclusion for templates/example-agents — reference prompts are tracked
# so collaborators inherit the same depth-and-structure inspiration.)
