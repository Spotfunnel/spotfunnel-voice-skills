# spotfunnel-voice-skills — environment variables
#
# Copy this file to `.env` at the repo root and fill in your own values.
# Never commit `.env` (it's gitignored).
#
# The skills resolve env file location in this order:
#   1. $SPOTFUNNEL_SKILLS_ENV (explicit override)
#   2. <repo-root>/.env (default — works when you run skills from a clone)
#   3. Cached path at ~/.config/spotfunnel-skills/env-path
#
# All values below are placeholders. Replace each one before running any skill.

# ====== Vendor APIs ======

# Ultravox — voice AI platform.
# Get from: https://app.ultravox.ai/ → Settings → API keys → Create.
ULTRAVOX_API_KEY=

# Telnyx — phone numbers + TeXML.
# Get from: https://portal.telnyx.com/ → API Keys.
TELNYX_API_KEY=

# Telnyx public key for Ed25519 webhook signature verification. Used by your
# dashboard-server (NOT directly by these skills) to verify call.ended webhooks.
# Get from: Telnyx Portal → Account (top right) → Settings → Public Key.
# Documented here so it's not forgotten when you set up the dashboard-server side.
TELNYX_PUBLIC_KEY=

# Firecrawl — full-site scrape used in /base-agent Stage 2.
# Get from: https://www.firecrawl.dev/app → API Keys.
FIRECRAWL_API_KEY=

# Resend — transactional email for pool-low alerts and onboarding magic links.
# Get from: https://resend.com/api-keys.
RESEND_API_KEY=

# Resend "from" address. Must be a verified sender on your Resend account.
# Suggested: noreply@<your-domain>
RESEND_FROM_EMAIL=

# ====== Operator's Backend ======

# Supabase — your dashboard's Supabase project.
# Find at: https://supabase.com/dashboard/project/<your-project>/settings/api
# If using a shared backend, paste the values your collaborator shared with you privately (don't post these in any public channel).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public URL of your deployed dashboard-server (the Railway/equivalent service
# that handles call.ended webhooks and routes to Supabase).
# Example: https://dashboard-server.your-domain.com
DASHBOARD_SERVER_URL=

# ====== Reference assets in your accounts ======

# Ultravox agent_id of YOUR existing reference agent — the one whose voice,
# temperature, inactivity messages, and first-speaker settings get copied
# onto every new customer agent. Pick one of your best-tuned production agents.
REFERENCE_ULTRAVOX_AGENT_ID=

# ====== n8n (for /onboard-customer error reporting) ======

# Base URL of your n8n instance (no trailing slash).
N8N_BASE_URL=

# Your n8n personal API key.
N8N_API_KEY=

# Workflow ID of your central error-reporter workflow in n8n.
# See docs/runbooks/n8n-error-wiring.md for how to create this.
N8N_ERROR_REPORTER_WORKFLOW_ID=

# ====== Alerting ======

# Where pool-low / pool-empty / onboarding alerts get sent.
# Suggested: ops@<your-domain> or your personal email during early days.
OPS_ALERT_EMAIL=
